# Required environment variables
# Copy this file to .env and fill in the values — never commit .env to git.

# From the Discord Developer Portal > Your Application > Bot > Token
DISCORD_TOKEN=

# From the Discord Developer Portal > Your Application > General Information > Application ID
CLIENT_ID=

# Right-click your test server in Discord (enable Developer Mode first) > Copy Server ID
GUILD_ID=

# Channel ID where completed guild applications are posted for staff review.
# Defaults to 1518623626247671878 in code if unset.
APPLICATION_CHANNEL_ID=1518623626247671878

# Optional: role ID whose members may approve/deny applications.
# Members with the Manage Server permission can always review regardless of this.
STAFF_ROLE_ID=

# MongoDB Atlas connection string for the Kudos system. Set the SAME value here
# (local) and in Railway → bot service → Variables, so laptop + Railway share one
# DB. If unset, the bot still runs — kudos is just disabled and its commands reply
# "not configured yet". See KUDOS-DEPLOY.md (incl. Atlas Network Access 0.0.0.0/0).
# Example: mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/
MONGODB_URI=
